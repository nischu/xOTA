<!doctype html>
<html>
  <head>
    #extend("include_head")
    <title>QSOs Graph</title>
  </head>
  <body>
    #extend("include_navbar")
    <div class="container">
    <div>
        <canvas id="qsosGraph"></canvas>
    </div>
<script src="/js/chart.umd.min.js"></script>
<script src="/js/chartjs-adapter-date-fns.bundle.min.js"></script>
<script>
  const ctx = document.getElementById('qsosGraph');
  let style = window.window.getComputedStyle(ctx);
  let bodyColor = style.getPropertyValue('--bs-body-color');
  let lineColor = style.getPropertyValue('--bs-emphasis-color');
  Chart.defaults.color = bodyColor;
  Chart.defaults.borderColor = bodyColor;

  new Chart(ctx, {
    type: 'line',
    data: {
      datasets: [{
        label: '# of QSOs',
        data: [#for(qso in qsos):{y: #(qso.count), x: "#(qso.date)"}#if(!isLast):,#endif#endfor],
        backgroundColor: lineColor,
        borderColor: lineColor,
        borderWidth: 1
      }]
    },
    options: {
      scales: {
        x: {
            adapters: {
                date: {

            }
          },
          type: 'time',
          time: {
            unit: 'hour',
            displayFormats: {
                hour: 'HH:mm'
            }
          },
        ticks: {
        major: {
           enabled: true, // <-- This is the key line
           fontStyle: 'bold', //You can also style these values differently
           fontSize: 14, //You can also style these values differently
        },
    },

        }
      }
    }
  });
</script>
    </div>
  </body>
</html>
